# Normalizacja końców linii (GitHub / Linux / Docker = LF)
* text=auto eol=lf

# Skrypty wykonywalne
*.sh text eol=lf

# Pliki binarne — bez konwersji LF/CRLF
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lockfile — traktuj jako tekst (czytelne diffy)
package-lock.json text eol=lf
uv.lock text eol=lf
