# =============================================================================
# Dixit AI — szablon zmiennych środowiskowych
# Skopiuj do pliku .env w katalogu głównym projektu:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)
# Nigdy nie commituj pliku .env — jest w .gitignore
# =============================================================================

# --- Baza danych (PostgreSQL) ---
DATABASE_URL="postgresql://username:password@localhost:5432/dixit_db"

# Opcjonalnie: osobna baza na testy API (Jest)
# DATABASE_URL_TEST="postgresql://username:password@localhost:5432/dixit_ai_test"

# --- Auth (wymagane) ---
JWT_SECRET="twoj-bardzo-tajny-klucz-jwt-min-32-znaki"

# --- Serwer Node ---
NODE_ENV=development
PORT=3000

# --- Redis (opcjonalnie, zakomentowane w app.js) ---
# REDIS_URL="redis://localhost:6379"

# --- Bot AI (FastAPI / Gemini) ---
GEMINI_API_KEY="twoj_klucz_gemini"

# --- Webhooki GitHub → Discord (opcjonalnie) ---
# GITHUB_WEBHOOK_SECRET=""
# DISCORD_WEBHOOK_URL=""
# DISCORD_THREAD_ID=""
# DISCORD_WEBHOOK_DRY_RUN=true
